datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  STAFF
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  orders    Order[]
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
}

model Order {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  productId     String?
  customerName  String?
  queueNumber   Int      @default(0)
  status        String   @default("PREPARING")
  createdAt     DateTime @default(now())
}